# Ad AI Pulse — environment configuration.
# Copy to .env.local and fill in. .env.local is gitignored; never commit real keys.

# Required: Gemini API key. Used server-side only (sent as x-goog-api-key).
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional tuning (sensible defaults applied if unset) ---

# Force cached output regardless of the UI toggle (flaky-wifi insurance on stage):
# DEMO_FORCE_CACHE=1

# Engine mode the UI opens in: cached | fast | agent
# DEMO_DEFAULT_MODE=cached

# Model for the "fast" structured path (override if 3.5-flash isn't served to your key):
# GEMINI_FAST_MODEL=gemini-2.5-flash

# TTS model for Rachel-voice briefings (falls back to browser Web Speech if unavailable):
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Antigravity (agent) timeout in ms before falling back to a cached brief:
# PULSE_TIMEOUT_MS=150000
