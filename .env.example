# Ad AI Pulse — environment configuration.
# Copy to .env.local and fill in. .env.local is gitignored; never commit real keys.

# Required: Gemini API key. Used server-side only (sent as x-goog-api-key).
GEMINI_API_KEY=your_gemini_api_key_here

# Optional backup key — geminiFetch fails over on 401/403/429.
# GEMINI_API_KEY_BACKUP=

# --- Image generation (cost control) ---
# Default model is gemini-2.5-flash-image (Nano Banana) — free-tier friendly on AI Studio.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Set to 1 to try Pro image first when you have budget (higher legibility).
# GEMINI_IMAGE_USE_PRO=0
# GEMINI_IMAGE_UPGRADE_MODEL=gemini-3-pro-image-preview
# Server-side cache TTL for generated infographics (ms). Default 24h.
# IMAGE_CACHE_TTL_MS=86400000

# --- WorkOS AuthKit (production access control) ---
# Get keys from https://dashboard.workos.com
# WORKOS_API_KEY=sk_test_...
# WORKOS_CLIENT_ID=client_...
# WORKOS_COOKIE_PASSWORD=  # openssl rand -base64 24  (min 32 chars)
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# NEXT_PUBLIC_WORKOS_AUTH_ENABLED=1
# AUTH_REQUIRED=1  # redirect unauthenticated users to AuthKit sign-in

# --- Optional tuning (sensible defaults applied if unset) ---

# Force cached output regardless of the UI toggle (flaky-wifi insurance on stage):
# DEMO_FORCE_CACHE=1

# Engine mode the UI opens in: cached | fast | agent
# DEMO_DEFAULT_MODE=cached

# Model for the "fast" structured path:
# GEMINI_FAST_MODEL=gemini-2.5-flash

# TTS model for Rachel-voice briefings (falls back to browser Web Speech if unavailable):
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Antigravity (agent) timeout in ms before falling back to a cached brief:
# PULSE_TIMEOUT_MS=150000
